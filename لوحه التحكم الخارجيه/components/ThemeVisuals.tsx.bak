                <path key={i} d={`M${x - 15},${y + 20} L${x},${y} L${x + 15},${y + 20} Z`}
                    fill={isDarkMode ? 'rgba(210,230,255,0.4)' : 'rgba(245,252,255,0.85)'} />
            ))}
            {/* Near hills — rich green */}
            <path d="M0,300 L0,250 L150,190 L300,240 L450,195 L600,245 L750,200 L900,240 L1000,210 L1000,300 Z"
                fill={isDarkMode ? '#1a3020' : '#3a7d44'} />
