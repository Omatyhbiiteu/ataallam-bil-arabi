            <path d="M0,300 L0,180 L80,100 L160,170 L240,80 L340,160 L420,70 L500,140 L580,60 L660,150 L750,85 L840,165 L920,90 L1000,140 L1000,300 Z"
                fill={isDarkMode ? 'rgba(30,40,60,0.7)' : 'rgba(180,200,220,0.6)'} />
            {/* Snow caps far */}
