# Development: `/api` — requests stay same-origin; Vite proxies to Laravel (see vite.config server.proxy).
# Production: full URL e.g. https://your-domain.com/api
VITE_BACKEND_API_URL=/api
# Target for the dev proxy (npm run dev only)
VITE_BACKEND_PROXY_URL=http://127.0.0.1:5000
# vite.config also tries 127.0.0.1:8000 if the configured port is not running.
# When this is active, the app will use your custom API instead of direct Firebase API calls.

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Admin Security
# Local security code for admin-only actions. Change it before sharing or deploying.
VITE_ADMIN_PASSWORD=change-this-security-code
VITE_ADMIN_LOGIN_EMAIL=admin@et3alem.local
# Keep this in sync with backend ADMIN_BOOTSTRAP_PASSWORD on a fresh database.
VITE_ADMIN_LOGIN_PASSWORD=change-this-admin-password
